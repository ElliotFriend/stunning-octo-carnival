        "@sveltejs/vite-plugin-svelte": "^7.1.3",
        "@types/node": "^24",
        "codama": "^1.8.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.20.0",
        "globals": "^17.7.0",
